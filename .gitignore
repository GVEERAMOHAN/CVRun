# Root .gitignore for CVRun project

# Frontend ignores
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/
frontend/*.local

# Backend ignores
backend/target/
backend/.project
backend/.classpath
backend/.settings/

# OS/IDE ignores
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.DS_Store
Thumbs.db
desktop.ini
